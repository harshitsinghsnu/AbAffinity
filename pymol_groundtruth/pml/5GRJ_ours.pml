# 5GRJ -- Ours (All-CDR) -- GT binding residues coloured by IG attribution
reinitialize
load pymol_groundtruth/pdb/pdb5grj.ent, 5GRJ
remove not polymer
remove 5GRJ and not chain H+L+A
hide everything
bg_color white
set ray_opaque_background, 1
set ray_shadows, 0
set ray_trace_mode, 1
set ray_trace_color, grey50
set antialias, 2
