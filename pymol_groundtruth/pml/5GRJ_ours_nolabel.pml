set light_count, 2
set specular, 0.15
set ambient, 0.45

set_view (\
   0.7960818, -0.6051045, 0.0101109,\
   0.0198532, 0.0094137, -0.9997586,\
   0.6048632, 0.7960904, 0.0195073,\
   0.0000000, 0.0000000, -148.8448181,\
   25.4879608, -80.6812973, 22.9356422,\
   117.3503876, 180.3392487, -20.0000000 )

set ray_trace_fog, 0
ray 2800, 2100
png pymol_groundtruth/figures/5GRJ_ours_nolabel.png, dpi=350, ray=0
save pymol_groundtruth/figures/5GRJ_ours_nolabel.pse
